---
import type { Language } from '@/i18n/config'
import LanguageSwitcherIcon from '@/assets/icons/language-switcher.svg'
import { moreLocales } from '@/config'
import { getNextGlobalLangPath, getNextSupportedLangPath } from '@/i18n/path'

interface Props {
  supportedLangs: Language[]
}

const { supportedLangs } = Astro.props
const currentPath = Astro.url.pathname

// Check if there are other languages to switch
const showLanguageSwitcher = moreLocales.length > 0
// Choose a language switch list according to supported languages
const nextUrl = supportedLangs.length > 0
  ? getNextSupportedLangPath(currentPath, supportedLangs) // Use supported languages when available
  : getNextGlobalLangPath(currentPath) // Fallback to all languages when no supported languages data
---

<!-- Theme Toggle -->
<button
  id="theme-toggle-button"
  class="theme-toggle mode-toggle"
  type="button"
  aria-label="切换明暗模式"
>○ 日光</button>

<!-- Palette Switcher -->
<div id="palette-segments" class="palette-segments" aria-label="切换纸色">
  <button class="palette-segment" type="button" data-palette-id="paper">宣</button>
  <button class="palette-segment" type="button" data-palette-id="silk">绢</button>
  <button class="palette-segment" type="button" data-palette-id="indigo">黛</button>
</div>

<!-- Language Switcher -->
{showLanguageSwitcher && (
  <a
    id="language-switcher"
    href={nextUrl}
    aria-label="Switch website language"
  >
    <LanguageSwitcherIcon
      aria-hidden="true"
      fill="currentColor"
    />
  </a>
)}

<!-- Theme Toggle Script >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> -->
<script>
import { secretPalettes, themePalettes } from '@/config'

// Whether the user has unlocked secret palettes via Konami code
function isSecretUnlocked() {
  return localStorage.getItem('palette-secret') === '1'
}

// Combined palette list: secret palettes only available after unlock
function getCyclePalettes() {
  return isSecretUnlocked() ? [...themePalettes, ...secretPalettes] : themePalettes
}

// Resolve the active palette, falling back to the first configured one
function currentPalette() {
  const saved = document.documentElement.dataset.palette || localStorage.getItem('palette')
  const all = getCyclePalettes()
  return all.find(p => p.id === saved) ?? all[0]
}

// Sync meta theme-color with the current palette and mode
function updateMetaThemeColor() {
  const metaThemeColor = document.head.querySelector('meta[name="theme-color"]')
  const palette = currentPalette()
  const isDark = document.documentElement.classList.contains('dark')
  metaThemeColor?.setAttribute('content', isDark ? palette.dark : palette.light)
}

function syncPaletteSegments() {
  const current = currentPalette().id
  document.querySelectorAll<HTMLButtonElement>('[data-palette-id]').forEach((button) => {
    const active = button.dataset.paletteId === current
    button.classList.toggle('is-active', active)
    button.setAttribute('aria-pressed', String(active))
  })
}

function renderSecretPalette(animate = false) {
  const segments = document.getElementById('palette-segments')
  const palette = secretPalettes[0]
  if (!segments || !isSecretUnlocked() || segments.querySelector(`[data-palette-id="${palette.id}"]`)) {
    return
  }

  // `palette-secret` only carries the one-shot unlock animation; on later
  // page loads the segment renders as a plain sibling (no replay flicker).
  const button = document.createElement('button')
  button.type = 'button'
  button.className = animate ? 'palette-segment palette-secret' : 'palette-segment'
  button.dataset.paletteId = palette.id
  button.textContent = palette.label
  segments.append(button)
}

function setPalette(id: string) {
  const palette = getCyclePalettes().find(item => item.id === id)
  if (!palette) {
    return
  }

  document.documentElement.dataset.palette = palette.id
  localStorage.setItem('palette', palette.id)
  updateMetaThemeColor()
  syncPaletteSegments()
}

// Apply theme changes
function applyTheme(isDark: boolean) {
  document.documentElement.classList.toggle('dark', isDark)
  updateMetaThemeColor()

  localStorage.setItem('theme', isDark ? 'dark' : 'light')
  document.dispatchEvent(new Event('theme-changed'))

  const themeButton = document.getElementById('theme-toggle-button')
  if (themeButton) {
    themeButton.textContent = isDark ? '◐ 夜色' : '○ 日光'
  }
}

// Toggle theme mode
function toggleTheme() {
  const isDark = !document.documentElement.classList.contains('dark')
  applyTheme(isDark)
}

// Run an update through the View Transitions API when motion is allowed
function runWithViewTransition(update: () => void) {
  // If reduceMotion is enabled, update theme directly
  if (document.documentElement.classList.contains('reduce-motion')) {
    update()
    return
  }

  // Add temporary markers before view transition
  document.documentElement.style.setProperty('view-transition-name', 'theme-toggle-transition')
  document.documentElement.setAttribute('data-theme-changing', '')

  // Use View Transitions API for theme toggle
  const transition = document.startViewTransition(update)

  // Remove temporary markers after view transition
  transition.finished.then(() => {
    document.documentElement.style.removeProperty('view-transition-name')
    document.documentElement.removeAttribute('data-theme-changing')
  })
}

function stampSeal() {
  const seal = document.querySelector<HTMLElement>('[role="img"][aria-label$="字印章"]')
  if (!seal) {
    return
  }

  seal.classList.remove('seal-stamp')
  void seal.offsetWidth
  seal.classList.add('seal-stamp')
}

// Handle theme toggle click events
function handleThemeToggle(e: MouseEvent) {
  if (!(e.target instanceof Element)) {
    return
  }

  if (e.target.closest('#theme-toggle-button')) {
    runWithViewTransition(toggleTheme)
    return
  }

  const paletteButton = e.target.closest<HTMLButtonElement>('[data-palette-id]')
  if (paletteButton?.dataset.paletteId) {
    runWithViewTransition(() => setPalette(paletteButton.dataset.paletteId!))
  }
}

// Listen to system theme changes in real time
// Skipped once the user made an explicit choice.
function handleSystemChange(event: MediaQueryListEvent) {
  if (localStorage.getItem('theme')) {
    return
  }
  const isDark = event.matches
  applyTheme(isDark)
}

document.addEventListener('click', handleThemeToggle)
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', handleSystemChange)

// Konami code unlocks secret palettes (↑↑↓↓←→←→BA).
// Once unlocked, secretPalettes are merged into the cycle sequence permanently.
// Re-entering the code again is a no-op.
;(function initKonami() {
  const konami = [
    'ArrowUp',
    'ArrowUp',
    'ArrowDown',
    'ArrowDown',
    'ArrowLeft',
    'ArrowRight',
    'ArrowLeft',
    'ArrowRight',
    'b',
    'a',
  ]
  let index = 0
  document.addEventListener('keydown', (e) => {
    if (e.key === konami[index]) {
      index++
      if (index === konami.length) {
        if (!isSecretUnlocked()) {
          localStorage.setItem('palette-secret', '1')
          runWithViewTransition(() => {
            renderSecretPalette(true)
            setPalette(secretPalettes[0].id)
            stampSeal()
          })
        }
        index = 0
      }
    }
    else {
      index = 0
    }
  })
})()

// Synchronize controls after the initial render and every Astro page swap.
function initThemeButton() {
  const themeButton = document.getElementById('theme-toggle-button')
  if (themeButton) {
    const isDark = document.documentElement.classList.contains('dark')
    themeButton.textContent = isDark ? '◐ 夜色' : '○ 日光'
  }

  renderSecretPalette()
  syncPaletteSegments()
}

initThemeButton()
document.addEventListener('astro:page-load', initThemeButton)
</script>

<style>
  .mode-toggle,
  .palette-segment {
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.2;
    cursor: pointer;
  }

  .mode-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    color: var(--secondary);
    background: transparent;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    letter-spacing: 0;
    opacity: 1;
    transition: color 200ms ease-out, border-color 200ms ease-out;
  }

  .mode-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
    opacity: 1;
  }

  .palette-segments {
    display: inline-flex;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: 999px;
  }

  .palette-segment {
    padding: 4px 11px;
    color: var(--secondary);
    background: transparent;
    border: 0;
    transition: color 200ms ease-out, background-color 200ms ease-out;
  }

  .palette-segment:hover {
    color: var(--accent);
  }

  .palette-segment.is-active {
    color: var(--paper);
    background: var(--ink);
  }

  .palette-secret {
    animation: palette-reveal 220ms ease-out;
  }

  :global(.seal-stamp) {
    animation: seal-stamp 260ms cubic-bezier(0.22, 0.8, 0.35, 1);
  }

  @keyframes palette-reveal {
    from { opacity: 0; transform: translateX(-5px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes seal-stamp {
    0% { transform: rotate(var(--seal-rotate)) scale(1); }
    45% { transform: rotate(var(--seal-rotate)) scale(0.85) translateY(2px); }
    100% { transform: rotate(var(--seal-rotate)) scale(1); }
  }
</style>
