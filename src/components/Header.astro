---
import type { Language } from '@/i18n/config'
import Button from '@/components/Button.astro'
import Seal from '@/components/Seal.astro'
import { getPageInfo } from '@/utils/page'

interface Props {
  supportedLangs?: Language[]
}

const { supportedLangs = [] } = Astro.props
const { isHome, isPost, getLocalizedPath } = getPageInfo(Astro.url.pathname)
const currentPath = Astro.url.pathname

function getNavItemClass(href: string, isActive = false) {
  const active = isActive || (currentPath.includes(href) && href !== '/')
  return active ? 'nav-active' : ''
}

const navItems = [
  { href: '/', label: '文章', active: isHome || isPost },
  { href: '/archive/', label: '归档' },
  { href: '/projects/', label: '项目' },
  { href: '/friends/', label: '友链' },
  { href: '/now/', label: '此刻' },
  { href: '/about/', label: '关于' },
]
---

<header class="site-header">
  <a class="site-name" href={getLocalizedPath('/')}>
    <Seal size={34} />
    <span>Liushenwuzhu-Alpaca</span>
  </a>
  <nav class="site-nav" aria-label="站点导航">
    {navItems.map(item => (
      <a
        href={getLocalizedPath(item.href)}
        class={getNavItemClass(item.href, item.active)}
        aria-current={getNavItemClass(item.href, item.active) ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
    <a href={getLocalizedPath('/search/')} aria-label="搜索">搜索</a>
    <Button supportedLangs={supportedLangs} />
  </nav>
</header>

<style>
  .site-header {
    align-items: baseline;
    gap: 24px;
    padding: 28px 0 20px;
  }

  .site-name {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--ink);
    font-family: var(--serif);
    font-size: 19px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .site-nav {
    gap: 26px;
    align-items: center;
  }

  .site-nav a {
    position: relative;
    padding-bottom: 3px;
    color: var(--secondary);
    opacity: 1;
    transition: color 200ms ease-out;
  }

  .site-nav a[aria-current='page'] {
    color: var(--ink);
    box-shadow: none;
  }

  .site-nav a[aria-current='page']::after {
    position: absolute;
    right: 0;
    bottom: -2px;
    left: 0;
    height: 2px;
    content: '';
    background: var(--accent);
  }

  .site-nav a:hover {
    color: var(--accent);
    opacity: 1;
  }
</style>
