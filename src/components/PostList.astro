---
import type { Language } from '@/i18n/config'
import type { Post } from '@/types'
import PinIcon from '@/assets/icons/pin-icon.svg'
import PostDate from '@/components/PostDate.astro'
import { getPostPath } from '@/i18n/path'
import { getPostDescription } from '@/utils/description'

export interface Props {
  posts: Post[]
  lang: Language
  pinned?: boolean
}

const { posts, lang, pinned = false } = Astro.props
---

<div class="rows">
  {posts.map((post) => {
    const slug = post.data.abbrlink || post.id
    const desc = getPostDescription(post, 'list')
    return (
      <a class="row" href={getPostPath(slug, lang)} transition:name={`post-${slug}${lang ? `-${lang}` : ''}`} data-disable-theme-toggle-transition>
        <span class="date"><PostDate date={post.data.published} minutes={post.remarkPluginFrontmatter.minutes} /></span>
        <h3><span class="u">{post.data.title}</span>{pinned && <PinIcon class="ml-1 inline-block w-0.85em align-baseline" fill="currentColor" aria-hidden="true" />}</h3>
        {desc && <p>{desc}</p>}
      </a>
    )
  })}
</div>
