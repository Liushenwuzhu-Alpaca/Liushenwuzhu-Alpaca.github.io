---
import type { Post } from '@/types'

interface Props {
  prev: Post | null
  next: Post | null
  lang?: string
}

const { prev, next, lang } = Astro.props
---

<div class="rows">
  {prev && (
    <a class="row" href={`/${lang ? `${lang}/` : ''}posts/${prev.data.abbrlink || prev.id}`}>
      <span class="post-nav-label">← 上一篇</span>
      <h3><span class="u">{prev.data.title}</span></h3>
    </a>
  )}
  {next && (
    <a class="row" href={`/${lang ? `${lang}/` : ''}posts/${next.data.abbrlink || next.id}`}>
      <span class="post-nav-label">→ 下一篇</span>
      <h3><span class="u">{next.data.title}</span></h3>
    </a>
  )}
</div>

<style>
  .post-nav-label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--accent);
    display: block;
    margin-bottom: 2px;
  }
  .rows .row:only-child {
    border-bottom: none;
  }
</style>
