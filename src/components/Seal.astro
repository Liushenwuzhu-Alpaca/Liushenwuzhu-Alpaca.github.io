---
// Cinnabar name seal - the only hard-coded color on the site by design.
---

<svg class="seal" viewBox="0 0 28 28" width="28" height="28" role="img" aria-label="向字印章">
  <rect x="0.5" y="0.5" width="27" height="27" rx="2" fill="#B13B2E" />
  <text x="14" y="14" text-anchor="middle" dominant-baseline="central" class="seal-char">向</text>
</svg>

<style>
  .seal {
    opacity: 0.88;
    transform: rotate(-2deg);
    transition: opacity 0.25s ease;
  }
  .seal:hover {
    opacity: 1;
  }
  .seal-char {
    fill: var(--paper);
    font-family: var(--serif);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0;
  }
</style>
