---
interface Props {
  char?: string
  size?: number
  rotate?: number
  vertical?: boolean
}

const {
  char = '驼',
  size = 34,
  rotate = -2,
  vertical = false,
} = Astro.props
---

<div
  class:list={['seal', { 'seal--vertical': vertical }]}
  style={`--seal-size: ${size}px; --seal-rotate: ${rotate}deg;`}
  role="img"
  aria-label={`${char}字印章`}
>
  {char}
</div>

<style>
  .seal {
    width: var(--seal-size);
    min-height: var(--seal-size);
    box-sizing: border-box;
    display: grid;
    place-items: center;
    padding: 0.08em;
    flex: none;
    background: var(--seal);
    color: var(--paper);
    border-radius: 4px;
    box-shadow: inset 0 0 0 2.5px color-mix(in srgb, var(--paper) 50%, transparent);
    font-family: var(--serif);
    font-size: calc(var(--seal-size) * 0.55);
    font-weight: 700;
    line-height: 1;
    transform: rotate(var(--seal-rotate));
  }

  .seal--vertical {
    width: var(--seal-size);
    min-height: calc(var(--seal-size) * 1.5);
    padding: 0.18em 0.12em;
    writing-mode: vertical-rl;
    letter-spacing: 0.18em;
  }
</style>
