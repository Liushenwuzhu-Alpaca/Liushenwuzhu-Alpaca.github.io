---
// Cinnabar name seal — the only hard-coded color on the site by design.
---

<svg class="seal" viewBox="0 0 28 28" width="28" height="28" role="img" aria-label="羊驼印章">
  <rect x="0.5" y="0.5" width="27" height="27" rx="2" fill="#B13B2E" />
  <text x="14" y="12.5" text-anchor="middle" class="seal-char">羊</text>
  <text x="14" y="23.5" text-anchor="middle" class="seal-char">驼</text>
</svg>

<style>
  .seal {
    opacity: 0.88;
    transform: rotate(-2deg);
    transition: opacity 0.25s ease;
  }
  .seal:hover {
    opacity: 1;
  }
  .seal-char {
    fill: var(--paper);
    font-family: var(--serif);
    font-weight: 700;
    font-size: 10.5px;
  }
</style>
