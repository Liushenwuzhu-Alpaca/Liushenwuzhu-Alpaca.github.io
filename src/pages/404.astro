---
import Layout from '@/layouts/Layout.astro'
---

<Layout>
  <section aria-labelledby="not-found-title">
    <p class="label">404 · 迷路</p>
    <h1 id="not-found-title" class="page-title">页面未找到</h1>
    <p style="opacity: 0.75; margin-bottom: 34px;">
      你要找的页面不存在，或已被移动。
    </p>
    <div class="rows">
      <a class="row" href="/">
        <h3><span class="u">回到首页</span> <span class="arrow">-&gt;</span></h3>
      </a>
      <a class="row" href="/archive/">
        <h3><span class="u">浏览全部文章</span> <span class="arrow">-&gt;</span></h3>
      </a>
    </div>
  </section>
</Layout>
