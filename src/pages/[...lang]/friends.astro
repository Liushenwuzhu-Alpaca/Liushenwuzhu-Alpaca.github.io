---
import { allLocales } from '@/config'
import { getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

/*
 * 添加友链格式：
 * {
 *   name: '站点名称',
 *   url: 'https://example.com',
 *   desc: '站点描述（可选，留空则不显示）',
 *   avatar: 'https://example.com/avatar.png（可选，留空则不显示头像）',
 * }
 */
const friends: { name: string, url: string, desc?: string, avatar?: string }[] = [
  {
    name: 'Mirawind\'s Blog',
    url: 'https://mirawind.top/',
    desc: '相寻梦里路，飞雨落花中',
    avatar: 'https://avatars.githubusercontent.com/u/53815918?v=4',
  },
]
---

<Layout>
  <section aria-labelledby="friends-title">
    <p class="label">Links · 友邻</p>
    <h1 id="friends-title" class="page-title">友链</h1>
    <div class="rows">
      {friends.length > 0
? (
        friends.map(friend => (
          <a class="row friend-row" href={friend.url}>
            <div class="friend-main">
              {friend.avatar && (
                <img
                  class="friend-avatar"
                  src={friend.avatar}
                  alt=""
                  loading="lazy"
                  width="48"
                  height="48"
                />
              )}
              <div class="friend-text">
                <h3>
                  <span class="u">{friend.name}</span> <span class="arrow">-&gt;</span>
                </h3>
                {friend.desc && <p>{friend.desc}</p>}
              </div>
            </div>
          </a>
        ))
      )
: (
        <a class="row" href="/about/">
          <h3>
            <span class="u">还没有友链，欢迎到关于页找我交换。</span> <span class="arrow">-&gt;</span>
          </h3>
        </a>
      )}
    </div>
  </section>
</Layout>

<style>
  .friend-row {
    padding: 18px 2px;
  }
  .friend-main {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .friend-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .friend-text h3 {
    margin: 0 0 3px;
  }
</style>
