---
import type { CollectionEntry } from 'astro:content'
import type { Language } from '@/i18n/config'
import { getCollection, render } from 'astro:content'
import Comment from '@/components/Comment/Index.astro'
import PostDate from '@/components/PostDate.astro'
import PostNav from '@/components/PostNav.astro'
import ReadingProgress from '@/components/ReadingProgress.astro'
import RelatedPosts from '@/components/RelatedPosts.astro'
import SeriesBox from '@/components/SeriesBox.astro'
import TagList from '@/components/TagList.astro'
import BackButton from '@/components/Widgets/BackButton.astro'
import TOC from '@/components/Widgets/TOC.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'
import { checkPostSlugDuplication, getAdjacentPosts, getRelatedPosts } from '@/utils/content'
import { getPostDescription } from '@/utils/description'
import { getGrowthStage, getRevisionCount } from '@/utils/postmeta'


export async function getStaticPaths() {
  const posts: CollectionEntry<'posts'>[] = await getCollection('posts')

  // Check if there are duplicate post slugs
  const duplicates = await checkPostSlugDuplication(posts)
  if (duplicates.length > 0) {
    throw new Error(`Duplicate post slugs:\n${duplicates.join('\n')}`)
  }

  // >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  // Build a map of post slugs to their supported languages
  // Handles both specific language posts (e.g., 'en') and universal posts (lang: '')
  const slugToLangsMap = new Map<string, Set<Language>>()

  for (const post of posts) {
    const slug = post.data.abbrlink || post.id.replace(/\.(md|mdx)$/, '')
    const lang = post.data.lang

    let langSet = slugToLangsMap.get(slug)
    if (!langSet) {
      langSet = new Set()
      slugToLangsMap.set(slug, langSet)
    }

    if (lang) {
      langSet.add(lang as Language)
    }
    else {
      allLocales.forEach(locale => langSet.add(locale))
    }
  }

  // Convert the map to a sorted record for the component props
  // Ensure languages are always sorted by the order defined in config
  const slugToLangs: Record<string, Language[]> = {}
  for (const [slug, langs] of slugToLangsMap) {
    slugToLangs[slug] = [...langs].sort((a, b) => allLocales.indexOf(a) - allLocales.indexOf(b))
  }
  // >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

  return allLocales.flatMap(lang => posts
    // Show drafts in dev mode only
    .filter(post => import.meta.env.DEV || !post.data.draft)
    // Match current language or universal posts
    .filter(post => post.data.lang === lang || post.data.lang === '')
    .map((post) => {
      const slug = post.data.abbrlink || post.id.replace(/\.(md|mdx)$/, '')
      return {
        params: { lang: getLangRouteParam(lang), slug },
        props: { post, supportedLangs: slugToLangs[slug] },
      }
    }),
  )
}

interface Props {
  post: CollectionEntry<'posts'>
  supportedLangs: Language[]
}

const { post, supportedLangs } = Astro.props
const currentLang = getLangFromLocale(Astro.currentLocale)
const slug = post.data.abbrlink || post.id.replace(/\.(md|mdx)$/, '')
const description = getPostDescription(post, 'meta')
const { Content, headings, remarkPluginFrontmatter } = await render(post)
const { prev, next } = await getAdjacentPosts(slug, currentLang)
const relatedPosts = await getRelatedPosts(slug, currentLang)
// Resolve the content file path for git-based revision counting.
// The content loader uses `src/content/posts/` as base — reconstruct the path.
const contentPath = `src/content/posts/${post.id}`
const stage = getGrowthStage(post.data)
const revisionCount = getRevisionCount(contentPath)
---
<ReadingProgress />
<Layout
  postTitle={post.data.title}
  postDescription={description}
  postSlug={post.data.abbrlink || post.id.replace(/\.(md|mdx)$/, '')}
  supportedLangs={supportedLangs}
>
  <article class="heti">
    <div class="relative">
      <!-- Go Back Button On Desktop -->
      <BackButton />
      <!-- Back Link On Mobile -->
      <a href="/archive/" class="mobile-back lg:hidden">← 全部文章</a>
      <!-- Title -->
      <h1 class="post-title">
        <span
          transition:name={`post-${slug}${currentLang ? `-${currentLang}` : ''}`}
          data-disable-theme-toggle-transition
        >
          {post.data.title}
        </span>
      </h1>
    </div>

    <!-- Date -->
    <div
      id="post-date"
      class="font-time mb-17.2 block c-primary"
      transition:name={`time-${slug}${currentLang ? `-${currentLang}` : ''}`}
      data-disable-theme-toggle-transition
    >
      <PostDate
        date={post.data.published}
        updatedDate={post.data.updated}
        minutes={remarkPluginFrontmatter.minutes}
      />
      <span class="ml-3 text-3.5 c-secondary">{stage.icon} {stage.label}</span>
    </div>

    <!-- TOC -->
    {post.data.toc && <TOC headings={headings} />}
    <!-- Content -->
    <div id="post-content">
      <Content />
    </div>
    <!-- Copyright -->
    <div id="post-copyright" />
    <!-- Tag List -->
    {post.data.tags?.length > 0 && (
      <hr class="hairline mt-12.6" />
      <TagList
        tags={post.data.tags}
        lang={currentLang}
      />
    )}
    {post.data.series && (
      <SeriesBox series={post.data.series} currentId={slug} lang={currentLang} />
    )}
      {relatedPosts.length > 0 && (
        <hr class="hairline mt-12.6" />
        <RelatedPosts posts={relatedPosts} lang={currentLang} />
      )}
      {revisionCount !== null && revisionCount > 1 && (
        <>
          <hr class="hairline mt-12.6" />
          <p class="mono text-3.5 c-secondary">{revisionCount} 次修订 · <a href={`https://github.com/Liushenwuzhu-Alpaca/Liushenwuzhu-Alpaca.github.io/commits/main/${contentPath}`} target="_blank" rel="noopener noreferrer" class="underline c-secondary">查看修订历史</a></p>
        </>
      )}
      {(prev || next) && (
        <hr class="hairline mt-12.6" />
        <PostNav {prev} {next} lang={currentLang} />
      )}
      <Comment />
  </article>
</Layout>
