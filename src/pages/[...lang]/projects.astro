---
import { allLocales } from '@/config'
import { getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'
import { getPublicRepos } from '@/utils/github'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

// Build-time GitHub sync; falls back to the static list when offline or rate-limited.
const fallbackProjects = [
  {
    name: '个人博客',
    description: '用 Astro 构建的静态个人站点，记录学习、项目与生活。',
    url: 'https://github.com/Liushenwuzhu-Alpaca/Liushenwuzhu-Alpaca.github.io',
    stars: null as number | null,
  },
]

const repos = await getPublicRepos('Liushenwuzhu-Alpaca')
const projects = repos
  ? repos.map(repo => ({
      name: repo.name,
      description: repo.description ?? '暂无描述',
      url: repo.url,
      stars: repo.stars,
    }))
  : fallbackProjects

/*
 * Repos you collaborate on but do not own. GitHub's public API only lists
 * repos you own, so maintain this list manually:
 * { name: 'owner/repo', description: '一句话说明', url: 'https://github.com/owner/repo', role: '协作' }
 * An empty array hides the whole section.
 */
const collaborations: { name: string, description: string, url: string, role?: string }[] = []
---

<Layout>
  <section aria-labelledby="projects-title">
    <p class="label">Projects · 造物</p>
    <h1 id="projects-title" class="page-title">项目</h1>
    <div class="rows">
      {projects.map(project => (
        <a class="row" href={project.url} target="_blank" rel="noopener">
          <h3><span class="u">{project.name}</span> <span class="arrow">-&gt;</span></h3>
          <p>{project.description}</p>
          {project.stars !== null && <p class="font-time text-3.5 c-secondary">★ {project.stars}</p>}
        </a>
      ))}
    </div>

    {collaborations.length > 0 && (
      <h2 class="label mt-12">Collaborations · 协作</h2>
      <div class="rows">
        {collaborations.map(repo => (
          <a class="row" href={repo.url} target="_blank" rel="noopener">
            <h3><span class="u">{repo.name}</span> <span class="arrow">-&gt;</span></h3>
            <p>{repo.description}</p>
            {repo.role && <p class="font-time text-3.5 c-secondary">{repo.role}</p>}
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
