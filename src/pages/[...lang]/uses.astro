---
import { allLocales } from '@/config'
import { getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

/*
 * Gear list format:
 * Add a group by appending an object to `data`:
 * {
 *   category: '硬件',  // group name; groups with empty items are not rendered
 *   items: [{ name: '笔记本', desc: 'model and one-line note' }],
 * }
 * Each entry is name + desc; an empty desc is hidden.
 */
const data: { category: string, items: { name: string, desc: string }[] }[] = [
  {
    category: '硬件',
    items: [
      { name: '笔记本', desc: 'Intel Core i7-14650HX + AMD Radeon Graphics (RDNA 3) 核显' },
    ],
  },
  {
    category: '软件与终端',
    items: [
      { name: '操作系统', desc: 'Arch Linux，滚动更新' },
      { name: '终端', desc: 'Ghostty 1.3.1，GPU 加速终端模拟器' },
      { name: '编辑器', desc: 'VS Code' },
    ],
  },
  {
    category: '其他',
    items: [],
  },
]
---

<Layout>
  <section aria-labelledby="uses-title">
    <p class="label">Uses · 装备</p>
    <h1 id="uses-title" class="page-title">装备</h1>
    {data.filter(group => group.items.length > 0).map(group => (
      <>
        <p class="group-heading">{group.category}</p>
        <div class="rows">
          {group.items.map(item => (
            <div class="row">
              <h3 class="item-name">{item.name}</h3>
              {item.desc && <p class="item-desc">{item.desc}</p>}
            </div>
          ))}
        </div>
      </>
    ))}
  </section>
</Layout>

<style>
  .group-heading {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
    margin-top: 32px;
  }
  .group-heading:first-of-type {
    margin-top: 0;
  }
  .item-name {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 500;
    margin: 0;
  }
  .item-desc {
    margin: 4px 0 0;
    font-size: 14px;
    opacity: 0.75;
    line-height: 1.5;
  }
</style>
