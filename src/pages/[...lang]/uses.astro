---
import { allLocales } from '@/config'
import { getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

/*
 * Gear list format:
 * Add a group by appending an object to `data`:
 * {
 *   category: '硬件',  // group name; groups with empty items are not rendered
 *   items: [{ name: '笔记本', desc: 'model and one-line note' }],
 * }
 * Each entry is name + desc; an empty desc is hidden.
 */
const data: { category: string, items: { name: string, desc: string }[] }[] = [
  {
    category: '硬件',
    items: [
      { name: '游戏本', desc: '惠普 光影精灵9 Intel Core i7-14650HX +  NVIDIA GeForce RTX 4060 核显' },
      { name: '轻薄本', desc: '机械革命 星耀14 AMD Ryzen 7 7840U + AMD Radeon 780M 核显' },
    ],
  },
  {
    category: '软件与终端',
    items: [
      { name: '操作系统（游戏本）', desc: 'Arch Linux, Windows 11' },
      { name: '操作系统（轻薄本）', desc: 'Fedora 44, Windows 11' },
      { name: '桌面环境', desc: 'KDE Plasma' },
      { name: '终端', desc: 'Ghostty' },
      { name: '编辑器', desc: 'Zed, VSCode' },
      { name: '浏览器', desc: 'Zen' },
      { name: 'AGENT', desc: 'oh-my-pi, opencode(omo-slim)' },
    ],
  },
  {
    category: '其他',
    items: [],
  },
]
const populatedGroups = data.filter(group => group.items.length > 0)
---

<Layout>
  <section aria-labelledby="uses-title">
    <h1 id="uses-title" class="label">Uses · 装备</h1>
    {populatedGroups.length > 0
? populatedGroups.map(group => (
      <>
        <p class="group-heading">{group.category}</p>
        <div class="rows">
          {group.items.map(item => (
            <div class="row">
              <h3 class="item-name">{item.name}</h3>
              {item.desc && <p class="item-desc">{item.desc}</p>}
            </div>
          ))}
        </div>
      </>
    ))
: (
      <div class="empty-state">
        <p class="empty-state__title">案头尚未添置。</p>
        <p class="empty-state__note">正在筛选，留下真正常用的器物。</p>
      </div>
    )}
  </section>
</Layout>

<style>
  .group-heading {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
    margin-top: 32px;
  }
  .group-heading:first-of-type {
    margin-top: 0;
  }
  .item-name {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 500;
    margin: 0;
  }
  .item-desc {
    margin: 4px 0 0;
    font-size: 14px;
    opacity: 0.75;
    line-height: 1.5;
  }
  .empty-state {
    display: grid;
    min-height: 160px;
    padding: 28px;
    border: 1px dashed var(--hairline);
    place-content: center;
    text-align: center;
  }
  .empty-state__title {
    margin: 0;
    font-size: 19px;
    font-weight: 600;
  }
  .empty-state__note {
    margin: 8px 0 0;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--secondary);
  }
</style>
